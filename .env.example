# Copy to .env. Everything here is optional except where noted.

# --- Window summon ---------------------------------------------------------
# Global show/hide hotkey (Electron accelerator). Avoid Ctrl+Alt+<key> (AltGr on
# many layouts) and Ctrl+Shift+W (closes editor tabs).
CLAUDE_WATCH_HOTKEY=Alt+C
CLAUDE_WATCH_PORT=7459              # local daemon port (hooks POST here)
CLAUDE_WATCH_MOCK=0                 # 1 = start with sample data matching the design
CLAUDE_WATCH_NOTIFICATIONS=0       # 1 = desktop "needs input" notifications (off: noisy)

# --- Meter 1: YOU · MAX (personal subscription windows) --------------------
# Real 5h + weekly windows come from the OAuth usage endpoint using the token in
# ~/.claude/.credentials.json (your Claude Code login). Nothing to configure.
# "Today tokens out" is summed from local transcripts:
# CLAUDE_WATCH_PROJECTS_DIR=         # defaults to ~/.claude/projects

# --- Meter 2: ORG · API (admin API token usage) ----------------------------
# Admin key (sk-ant-admin...) for the org's API-key usage + cost. A different
# account than the personal subscription meter above.
ANTHROPIC_ADMIN_KEY=
CLAUDE_WATCH_ORG_NAME=Growth Saloon   # label for the API meter
CLAUDE_WATCH_ORG_DAILY_BUDGET_USD=    # optional: shows a daily-spend budget bar

# (Future) a separate org *subscription* would live in the desktop app's
# claude.ai web session and could add a second window meter — not wired yet.
