{
  "name": "claude-watch-win",
  "version": "0.1.0",
  "description": "Hotkey-summoned Claude Code agent + API usage monitor for Windows (claude-watch, re-imagined for Win).",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "icons": "node scripts/gen-icon.mjs 256 && node scripts/gen-icon.mjs 32",
    "hooks:install": "node hooks/install.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "koffi": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^42.5.0",
    "electron-vite": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^7.0.0"
  }
}
